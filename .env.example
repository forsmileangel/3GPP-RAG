# Copy this file to .env and fill in real values.
# .env is git-ignored — do NOT commit secrets.

# --- LLM Providers (擇一或多個) ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# --- Local LLM (optional) ---
# 若用 Ollama,Provider 抽象層讀這個 base URL
OLLAMA_BASE_URL=http://localhost:11434

# --- Paths (可被 config.yaml 覆蓋) ---
# DATA_DIR=./data
# DB_PATH=./data/db/metadata.sqlite
# CHROMA_PATH=./data/db/chroma

# --- App ---
# 預設 visibility 角色:private | shared | public
DEFAULT_VISIBILITY=private

# --- Evidence gate (Step 5) — uncomment to override the calibrated defaults ---
# Operates in the [0,1] normalized score space; see src/retrieval/gate.py and
# research/scans/2026-06-13-gate-calibration.md. Retune if corpus/index changes.
# GATE_MODE=balanced            # balanced | strict | permissive
# GATE_ANSWER_FLOOR=0.65
# GATE_LOW_FLOOR=0.50
# GATE_MIN_TOP_SCORE=0.20
# GATE_STRONG_SCORE=0.55
# GATE_W_SCORE=0.2
# GATE_W_CONSIST=0.2
# GATE_W_COVER=0.6
# GATE_MIN_RESULTS=2
